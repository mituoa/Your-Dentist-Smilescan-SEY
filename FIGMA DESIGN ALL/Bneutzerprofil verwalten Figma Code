                  )}
                </div>

                {/* Specialties */}
                <div>
                  <div className="flex items-center justify-between mb-3">
                    <label className="block text-[11px] font-medium" style={{ color: '#737373' }}>
                      Fachgebiete
                    </label>
                    <span className="text-[10px]" style={{ color: '#A3A3A3' }}>
                      {profileData.selectedSpecialties.length}/5
                    </span>
                  </div>
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '6px' }}>
                    {AVAILABLE_SPECIALTIES
                      .filter(s => {
                        // Show if: expanded view OR primary specialty OR currently selected
                        return showAllSpecialties ||
                               PRIMARY_SPECIALTIES.includes(s.id) ||
                               profileData.selectedSpecialties.includes(s.id);
                      })
                      .map(specialty => {
                        const isSelected = profileData.selectedSpecialties.includes(specialty.id);
                        const isDisabled = !isSelected && profileData.selectedSpecialties.length >= 5;
                        return (
                          <button key={specialty.id} onClick={() => !isDisabled && toggleSpecialty(specialty.id)} disabled={isDisabled}
                            className="text-[11px] font-medium px-3 py-1.5 rounded-sm"
                            style={{
                              background: isSelected ? '#262626' : '#FFFFFF',
                              color: isSelected ? '#FFFFFF' : '#737373',
                              border: `1px solid ${isSelected ? '#262626' : '#E8E8E8'}`,
                              opacity: isDisabled ? 0.3 : 1,
                              cursor: isDisabled ? 'not-allowed' : 'pointer',
                              transition: 'all 120ms ease',
                            }}
                          >
                            {specialty.label}
                          </button>
                        );
                      })}
                  </div>
                  {!showAllSpecialties && AVAILABLE_SPECIALTIES.length > PRIMARY_SPECIALTIES.length && (
                    <button
                      onClick={() => setShowAllSpecialties(true)}
                      className="text-[11px] font-medium mt-3"
                      style={{ color: '#999999', transition: 'all 120ms ease' }}
                    >
                      Weitere Fachgebiete anzeigen
                    </button>
                  )}
                </div>

                {/* Practice */}
                <div>
                  <label className="block text-[11px] font-medium mb-3" style={{ color: '#737373' }}>
                    Praxis
                  </label>
                  <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                    <input type="text" placeholder="Praxisname (optional)" value={profileData.practiceName}
                      onChange={(e) => setProfileData({ ...profileData, practiceName: e.target.value })}
                      className="w-full text-[13px] focus:outline-none"
                      style={{ padding: '9px 12px', border: '1px solid #E8E8E8', borderRadius: '3px', color: '#262626', background: '#FFFFFF', transition: 'all 120ms ease' }}
                      onFocus={(e) => { e.currentTarget.style.borderColor = '#2F80ED'; e.currentTarget.style.boxShadow = '0 0 0 3px rgba(47,128,237,0.06)'; }}
                      onBlur={(e) => { e.currentTarget.style.borderColor = '#E8E8E8'; e.currentTarget.style.boxShadow = 'none'; }}
                    />
                    <input type="text" placeholder="Straße und Hausnummer" value={profileData.street}
                      onChange={(e) => setProfileData({ ...profileData, street: e.target.value })}
                      className="w-full text-[13px] focus:outline-none"
                      style={{ padding: '9px 12px', border: '1px solid #E8E8E8', borderRadius: '3px', color: '#262626', background: '#FFFFFF', transition: 'all 120ms ease' }}
                      onFocus={(e) => { e.currentTarget.style.borderColor = '#2F80ED'; e.currentTarget.style.boxShadow = '0 0 0 3px rgba(47,128,237,0.06)'; }}
                      onBlur={(e) => { e.currentTarget.style.borderColor = '#E8E8E8'; e.currentTarget.style.boxShadow = 'none'; }}
                    />
                    <div className="grid grid-cols-3 gap-2">
                      <input type="text" placeholder="PLZ" value={profileData.postalCode}
                        onChange={(e) => setProfileData({ ...profileData, postalCode: e.target.value })}
                        className="w-full text-[13px] focus:outline-none"
                        style={{ padding: '9px 12px', border: '1px solid #E8E8E8', borderRadius: '3px', color: '#262626', background: '#FFFFFF', transition: 'all 120ms ease' }}
                        onFocus={(e) => { e.currentTarget.style.borderColor = '#2F80ED'; e.currentTarget.style.boxShadow = '0 0 0 3px rgba(47,128,237,0.06)'; }}
                        onBlur={(e) => { e.currentTarget.style.borderColor = '#E8E8E8'; e.currentTarget.style.boxShadow = 'none'; }}
                      />
                      <input type="text" placeholder="Stadt" value={profileData.city}
                        onChange={(e) => setProfileData({ ...profileData, city: e.target.value })}
                        className="col-span-2 w-full text-[13px] focus:outline-none"
                        style={{ padding: '9px 12px', border: '1px solid #E8E8E8', borderRadius: '3px', color: '#262626', background: '#FFFFFF', transition: 'all 120ms ease' }}
                        onFocus={(e) => { e.currentTarget.style.borderColor = '#2F80ED'; e.currentTarget.style.boxShadow = '0 0 0 3px rgba(47,128,237,0.06)'; }}
                        onBlur={(e) => { e.currentTarget.style.borderColor = '#E8E8E8'; e.currentTarget.style.boxShadow = 'none'; }}
                      />
                    </div>
                    <input type="text" placeholder="Öffnungszeiten" value={profileData.openingHours}
                      onChange={(e) => setProfileData({ ...profileData, openingHours: e.target.value })}
                      className="w-full text-[13px] focus:outline-none"
                      style={{ padding: '9px 12px', border: '1px solid #E8E8E8', borderRadius: '3px', color: '#262626', background: '#FFFFFF', transition: 'all 120ms ease' }}
                      onFocus={(e) => { e.currentTarget.style.borderColor = '#2F80ED'; e.currentTarget.style.boxShadow = '0 0 0 3px rgba(47,128,237,0.06)'; }}
                      onBlur={(e) => { e.currentTarget.style.borderColor = '#E8E8E8'; e.currentTarget.style.boxShadow = 'none'; }}
                    />
                  </div>
                </div>

              </div>
            </div>
          </div>

          {/* RIGHT SIDE - Final Profile */}
          <div className="flex-1 overflow-auto flex items-center justify-center" style={{ background: '#FAFAFA' }}>
            <div style={{ maxWidth: '560px', width: '100%', padding: '140px 64px 100px' }}>

              {/* Photo + Name (unified block) */}
              <div style={{ marginBottom: '88px', textAlign: 'center' }}>
                {/* Photo */}
                {profileData.photo && (
                  <div style={{ marginBottom: '24px', display: 'flex', justifyContent: 'center' }}>
                    <div style={{ width: '148px', height: '148px', borderRadius: '2px', overflow: 'hidden' }}>
                      <img src={profileData.photo} alt="Profil" className="w-full h-full object-cover" />
                    </div>
                  </div>
                )}

                {/* Name */}
                <h1 style={{ fontSize: '42px', fontWeight: 600, color: '#1a1a1a', letterSpacing: '-0.022em', lineHeight: '1.12', marginBottom: '14px' }}>
                  {profileData.title} {profileData.firstName} {profileData.lastName}
                </h1>
                {profileData.practiceName && (
                  <p style={{ fontSize: '16px', color: '#6b6b6b', fontWeight: 400 }}>
                    {profileData.practiceName}
                  </p>
                )}
              </div>

              {/* Working Style */}
              {getSelectedStatements().length > 0 && (
                <div style={{ marginBottom: '80px' }}>
                  <div style={{ display: 'flex', flexDirection: 'column' }}>
                    {getSelectedStatements().map((statement, index) => (
                      <p key={statement.id} style={{
                        fontSize: index === 0 ? '20px' : '17px',
                        color: '#262626',
                        lineHeight: index === 0 ? '1.45' : '1.65',
                        fontWeight: index === 0 ? 500 : 400,
                        textAlign: 'center',
                        marginBottom: index === 0 ? '40px' : (index === getSelectedStatements().length - 1 ? '0' : '20px')
                      }}>
                        {statement.text}
                      </p>
                    ))}
                  </div>
                </div>
              )}

              {/* Specialties */}
              {getSelectedSpecialties().length > 0 && (
                <div style={{ marginBottom: '64px' }}>
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '10px', justifyContent: 'center' }}>
                    {getSelectedSpecialties().map(specialty => (
                      <div key={specialty.id} style={{ fontSize: '13px', fontWeight: 400, padding: '7px 16px', borderRadius: '2px', background: '#F3F3F3', color: '#5c5c5c' }}>
                        {specialty.label}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Practice */}
              <div style={{ textAlign: 'center' }}>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '10px', fontSize: '15px', color: '#4d4d4d', lineHeight: '1.6' }}>
                  {(profileData.street || profileData.city) && (
                    <div>
                      {profileData.street && <div>{profileData.street}</div>}
                      {(profileData.postalCode || profileData.city) && (
                        <div>{profileData.postalCode} {profileData.city}</div>
                      )}
                    </div>
                  )}
                  {profileData.openingHours && (
                    <div>{profileData.openingHours}</div>
                  )}
                </div>
              </div>

            </div>
          </div>

        </div>
      </main>
    </div>
  );
}
