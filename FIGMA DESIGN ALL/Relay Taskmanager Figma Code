                                } else {
                                  setSelectedAssignees([...selectedAssignees, member.id]);
                                }
                              }}
                              className="w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-[#F8FAFC]"
                              style={{
                                transition: 'all 180ms ease',
                              }}
                            >
                              <div
                                className="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-semibold text-white"
                                style={{ background: member.color }}
                              >
                                {member.initials}
                              </div>
                              <span className="text-[14px]" style={{ color: '#1E293B' }}>{member.name}</span>
                              {selectedAssignees.includes(member.id) && (
                                <div className="ml-auto w-1.5 h-1.5 rounded-full" style={{ background: '#2F80ED' }} />
                              )}
                            </button>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>

                  {/* Important Toggle */}
                  <button
                    onClick={() => setIsImportant(!isImportant)}
                    className="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[#F8FAFC]"
                    style={{
                      background: isImportant ? 'rgba(220,38,38,0.06)' : 'transparent',
                      transition: 'all 180ms ease',
                      border: '1px solid #F1F5F9',
                    }}
                  >
                    <div className="w-1.5 h-1.5 rounded-full" style={{ background: isImportant ? '#DC2626' : '#CBD5E1' }} />
                    <span className="text-[13px]" style={{ color: isImportant ? '#DC2626' : '#64748B' }}>
                      Als wichtig markieren
                    </span>
                  </button>
                </div>
              )}
            </div>

            {/* BOARD - Kanban View */}
            <div className="grid grid-cols-3" style={{ gap: '24px' }}>
              {/* Column: Offen */}
              <div
                style={{
                  background: '#FFFFFF',
                  borderRadius: '12px',
                  padding: '20px',
                }}
              >
                <div className="flex items-center justify-between mb-4">
                  <h2 className="text-[13px] font-semibold uppercase tracking-wider"
                    style={{ color: '#64748B', letterSpacing: '0.05em' }}
                  >
                    Offen
                  </h2>
                  <span className="text-[12px] font-medium px-2 py-0.5 rounded-full"
                    style={{
                      background: '#F8FAFC',
                      color: '#64748B',
                    }}
                  >
                    {openTasks.length}
                  </span>
                </div>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
                  {openTasks.map(task => (
                    <TaskCard key={task.id} task={task} teamMembers={teamMembers} currentUserId={currentUserId} />
                  ))}
                </div>
              </div>

              {/* Column: In Bearbeitung */}
              <div
                style={{
                  background: 'rgba(47,128,237,0.02)',
                  borderRadius: '12px',
                  padding: '20px',
                }}
              >
                <div className="flex items-center justify-between mb-4">
                  <h2 className="text-[13px] font-semibold uppercase tracking-wider"
                    style={{ color: '#64748B', letterSpacing: '0.05em' }}
                  >
                    In Bearbeitung
                  </h2>
                  <span className="text-[12px] font-medium px-2 py-0.5 rounded-full"
                    style={{
                      background: '#F8FAFC',
                      color: '#64748B',
                    }}
                  >
                    {inProgressTasks.length}
                  </span>
                </div>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
                  {inProgressTasks.map(task => (
                    <TaskCard key={task.id} task={task} teamMembers={teamMembers} currentUserId={currentUserId} />
                  ))}
                </div>
              </div>

              {/* Column: Erledigt */}
              <div
                style={{
                  background: 'rgba(22,163,74,0.02)',
                  borderRadius: '12px',
                  padding: '20px',
                }}
              >
                <div className="flex items-center justify-between mb-4">
                  <h2 className="text-[13px] font-semibold uppercase tracking-wider"
                    style={{ color: '#64748B', letterSpacing: '0.05em' }}
                  >
                    Erledigt
                  </h2>
                  <span className="text-[12px] font-medium px-2 py-0.5 rounded-full"
                    style={{
                      background: '#F8FAFC',
                      color: '#64748B',
                    }}
                  >
                    {doneTasks.length}
                  </span>
                </div>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
                  {doneTasks.map(task => (
                    <TaskCard key={task.id} task={task} teamMembers={teamMembers} currentUserId={currentUserId} />
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  );
}
