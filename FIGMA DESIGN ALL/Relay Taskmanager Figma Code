// TaskCard Component
function TaskCard({ task, teamMembers, currentUserId }: { task: Task; teamMembers: TeamMember[]; currentUserId: string }) {
  const isDone = task.status === 'done';
  const isMyTask = task.assignedTo.includes(currentUserId);

  return (
    <div
      className="bg-white group cursor-pointer"
      style={{
        border: isMyTask ? '1px solid rgba(47,128,237,0.15)' : 'none',
        borderRadius: '8px',
        padding: '14px 16px',
        transition: 'all 180ms ease',
        background: isMyTask ? 'rgba(47,128,237,0.02)' : '#FFFFFF',
      }}
      onMouseEnter={(e) => {
        e.currentTarget.style.background = isMyTask ? 'rgba(47,128,237,0.04)' : '#F8FAFC';
      }}
      onMouseLeave={(e) => {
        e.currentTarget.style.background = isMyTask ? 'rgba(47,128,237,0.02)' : '#FFFFFF';
      }}
    >
      {/* Task Title with Important Indicator */}
      <div className="flex items-start gap-2 mb-3">
        {task.isImportant && (
          <div className="w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0" style={{ background: '#DC2626' }} />
        )}
        <h3
          className="text-[14px] font-medium flex-1"
          style={{
            color: isDone ? '#94A3B8' : '#1E293B',
            textDecoration: isDone ? 'line-through' : 'none',
            lineHeight: '1.45',
          }}
        >
          {task.title}
        </h3>
      </div>

      {/* Context */}
      {task.context && (
        <p className="text-[12px] mb-3" style={{ color: '#94A3B8', paddingLeft: task.isImportant ? '14px' : '0' }}>
          {task.context}
        </p>
      )}

      {/* Assignees */}
      <div className="flex items-center gap-1.5" style={{ paddingLeft: task.isImportant ? '14px' : '0' }}>
        {task.assignedTo.length > 1 && (
          <Users className="w-3 h-3 mr-0.5" style={{ color: '#94A3B8' }} />
        )}
        {task.assignedTo.map(id => {
          const member = teamMembers.find(m => m.id === id);
          return member ? (
            <div
              key={id}
              className="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-semibold text-white"
              style={{
                background: member.color,
                boxShadow: id === currentUserId ? '0 0 0 2px rgba(47,128,237,0.2)' : 'none'
              }}
              title={member.name}
            >
              {member.initials}
            </div>
          ) : null;
        })}
      </div>
    </div>
  );
}

