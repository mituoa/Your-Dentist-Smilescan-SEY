                  </form>
                </div>
              )}

              {/* Step 3: Verification */}
              {registrationStep === 3 && (
                <div style={{ animation: 'slideIn 0.4s ease-out' }}>
                  <div className="mb-7 text-center">
                    <h3 className="text-[24px] font-semibold text-gray-900 mb-1.5 tracking-tight">
                      Fast geschafft! 🎉
                    </h3>
                    <p className="text-[13px] text-gray-500">
                      Bitte verifizieren Sie Ihre Zahnarzt-Zulassung
                    </p>
                  </div>

                  <form onSubmit={handleRegister} className="space-y-5">

                    {/* Drag & Drop */}
                    <div>
                      <div
                        className={`relative border-2 border-dashed rounded-xl transition-all duration-300 ${
                          dragActive
                            ? 'border-[#0284C7] bg-[#0284C7]/10 scale-105'
                            : licenseFile
                            ? 'border-green-400 bg-green-50'
                            : 'border-gray-300 bg-white hover:border-[#0284C7] hover:bg-[#0284C7]/5 hover:scale-[1.02]'
                        }`}
                        style={{
                          boxShadow: dragActive ? '0 0 0 4px rgba(2, 132, 199, 0.1)' : 'none'
                        }}
                        onDragEnter={handleDrag}
                        onDragLeave={handleDrag}
                        onDragOver={handleDrag}
                        onDrop={handleDrop}
                      >
                        <input
                          id="license-file"
                          type="file"
                          accept="image/*,.pdf"
                          onChange={handleFileChange}
                          disabled={isRegistering}
                          className="hidden"
                          required
                        />
                        <label
                          htmlFor="license-file"
                          className="flex flex-col items-center justify-center py-12 px-6 cursor-pointer"
                        >
                          {licenseFile ? (
                            <div className="w-full" style={{ animation: 'fadeIn 0.3s ease-out' }}>
                              {filePreview ? (
                                <div className="mb-4 rounded-lg overflow-hidden border-2 border-green-200">
                                  <img src={filePreview} alt="Preview" className="w-full h-32 object-cover" />
                                </div>
                              ) : (
                                <div className="mb-4 flex items-center justify-center">
                                  <svg className="w-16 h-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
                                    <path strokeLinecap="round" strokeLinejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                  </svg>
                                </div>
                              )}
                              <div className="flex items-center justify-center gap-2 mb-2">
                                <svg className="w-5 h-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                                  <path strokeLinecap="round" strokeLinejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <p className="text-[14px] font-semibold text-gray-900 truncate max-w-[250px]">{licenseFile.name}</p>
                              </div>
                              <p className="text-[12px] text-gray-500 mb-3 text-center">
                                {(licenseFile.size / 1024 / 1024).toFixed(2)} MB
                              </p>
                              <button
                                type="button"
                                onClick={(e) => {
                                  e.preventDefault();
                                  setLicenseFile(null);
                                  setFilePreview(null);
                                }}
                                className="text-[13px] text-[#0284C7] hover:text-[#0369A1] font-medium transition-colors duration-150"
                              >
                                Andere Datei wählen
                              </button>
                            </div>
                          ) : (
                            <>
                              <div className="relative mb-3">
                                <svg className="w-14 h-14 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={1.5}>
                                  <path strokeLinecap="round" strokeLinejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                                </svg>
                                <div className="absolute -bottom-1 -right-1 w-6 h-6 bg-[#0284C7] rounded-full flex items-center justify-center">
                                  <svg className="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}>
                                    <path strokeLinecap="round" strokeLinejoin="round" d="M12 4v16m8-8H4" />
                                  </svg>
                                </div>
                              </div>
                              <p className="text-[15px] font-semibold text-gray-900 mb-1">
                                Zahnarztausweis hochladen
                              </p>
                              <p className="text-[12px] text-gray-500 mb-1">
                                Ziehen Sie die Datei hierher oder klicken Sie
                              </p>
                              <p className="text-[11px] text-gray-400">
                                JPG, PNG oder PDF (max. 10 MB)
                              </p>
                            </>
                          )}
                        </label>
                      </div>
                      <div
                        className="mt-3 rounded-lg p-3 flex items-start gap-2"
                        style={{
                          background: 'linear-gradient(135deg, rgba(2, 132, 199, 0.06) 0%, rgba(2, 132, 199, 0.03) 100%)',
                          border: '1px solid rgba(2, 132, 199, 0.2)'
                        }}
                      >
                        <svg className="w-4 h-4 text-[#0284C7] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                          <path strokeLinecap="round" strokeLinejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                        <p className="text-[12px] text-gray-700 leading-relaxed">Ihre Daten werden verschlüsselt und nur zur Verifizierung verwendet.</p>
                      </div>
                    </div>

                    {/* Selected Plan */}
                    <div
                      className="rounded-xl p-5"
                      style={{
                        background: 'linear-gradient(135deg, rgba(2, 132, 199, 0.08) 0%, rgba(2, 132, 199, 0.04) 100%)',
                        border: '1.5px solid rgba(2, 132, 199, 0.2)'
                      }}
                    >
                      <div className="flex items-center justify-between">
                        <div>
                          <p className="text-[11px] font-medium text-gray-600 mb-1 uppercase tracking-wide">Gewähltes Abo</p>
                          <p className="text-[18px] font-semibold text-gray-900">{plans[selectedPlan].label}</p>
                        </div>
                        <div className="text-right">
                          <p className="text-[26px] font-semibold text-[#0284C7]">€{plans[selectedPlan].price}</p>
                          <p className="text-[11px] text-gray-600">/Monat</p>
                        </div>
                      </div>
                    </div>

                    <div className="flex gap-3 pt-4">
                      <button
                        type="button"
                        onClick={() => setRegistrationStep(2)}
                        disabled={isRegistering}
                        className="flex-1 h-[56px] bg-white text-gray-700 border-2 border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 text-[15px] font-semibold active:scale-[0.98] disabled:opacity-50"
                      >
                        Zurück
                      </button>
                      <button
                        type="submit"
                        disabled={isRegistering}
                        className="flex-1 h-[56px] text-white rounded-xl transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed shadow-sm hover:shadow-lg text-[15px] font-semibold active:scale-[0.98] hover:scale-[1.01]"
                        style={{
                          background: 'linear-gradient(to bottom, #0284C7 0%, #0369A1 100%)',
                        }}
                        onMouseEnter={(e) => {
                          if (!isRegistering) {
                            e.currentTarget.style.background = 'linear-gradient(to bottom, #0369A1 0%, #075985 100%)';
                            e.currentTarget.style.transform = 'translateY(-1px)';
                          }
                        }}
                        onMouseLeave={(e) => {
                          e.currentTarget.style.background = 'linear-gradient(to bottom, #0284C7 0%, #0369A1 100%)';
                          e.currentTarget.style.transform = 'translateY(0)';
                        }}
                      >
                        {isRegistering ? (
                          <span className="flex items-center justify-center gap-2">
                            <svg className="animate-spin h-5 w-5" viewBox="0 0 24 24">
                              <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="3" fill="none" />
                              <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
                            </svg>
                            Wird überprüft...
                          </span>
                        ) : (
                          'Registrierung abschließen'
                        )}
                      </button>
                    </div>

                    <p className="text-[11px] text-gray-500 text-center pt-3">
                      Mit der Registrierung akzeptieren Sie unsere{' '}
                      <button type="button" className="text-[#0284C7] hover:underline">AGB</button>
                      {' '}und{' '}
                      <button type="button" className="text-[#0284C7] hover:underline">Datenschutzerklärung</button>
                    </p>
                  </form>
                </div>
              )}

              {/* Step 4: Success */}
              {registrationStep === 4 && (
                <div className="text-center py-6" style={{ animation: 'slideIn 0.4s ease-out' }}>
                  <div
                    className="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-5"
                    style={{
                      background: 'linear-gradient(135deg, #10B981 0%, #059669 100%)',
                      boxShadow: '0 8px 20px rgba(16, 185, 129, 0.4)',
                      animation: 'successPulse 0.6s ease-out'
                    }}
                  >
                    <svg
                      className="w-10 h-10 text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      strokeWidth={3}
                      style={{ animation: 'checkmarkDraw 0.5s ease-out 0.2s both' }}
                    >
                      <path strokeLinecap="round" strokeLinejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <h3 className="text-[26px] font-semibold text-gray-900 mb-2 tracking-tight">
                    Herzlich willkommen! 🎉
                  </h3>
                  <p className="text-[14px] text-gray-600 max-w-md mx-auto mb-7 leading-relaxed">
                    Wir überprüfen Ihren Zahnarztausweis und senden Ihnen innerhalb von <span className="font-semibold text-[#0284C7]">24 Stunden</span> eine Bestätigung per E-Mail.
                  </p>

                  <div
                    className="rounded-xl p-5 mb-7 text-left"
                    style={{
                      background: 'linear-gradient(135deg, rgba(2, 132, 199, 0.05) 0%, rgba(2, 132, 199, 0.02) 100%)',
                      border: '1px solid rgba(2, 132, 199, 0.15)',
                      animation: 'fadeIn 0.4s ease-out 0.3s both'
                    }}
                  >
                    <h4 className="text-[14px] font-semibold text-gray-900 mb-3">Nächste Schritte:</h4>
                    <ul className="space-y-2.5 text-[13px] text-gray-700">
                      <li className="flex items-start gap-2.5" style={{ animation: 'slideIn 0.4s ease-out 0.4s both' }}>
                        <span className="flex-shrink-0 flex items-center justify-center w-5 h-5 rounded-full bg-[#0284C7] text-white text-[10px] font-semibold mt-0.5">1</span>
                        <span>Prüfung Ihres Zahnarztausweises (max. 24h)</span>
                      </li>
                      <li className="flex items-start gap-2.5" style={{ animation: 'slideIn 0.4s ease-out 0.5s both' }}>
                        <span className="flex-shrink-0 flex items-center justify-center w-5 h-5 rounded-full bg-[#0284C7] text-white text-[10px] font-semibold mt-0.5">2</span>
                        <span>Bestätigungs-E-Mail mit Zugang</span>
                      </li>
                      <li className="flex items-start gap-2.5" style={{ animation: 'slideIn 0.4s ease-out 0.6s both' }}>
                        <span className="flex-shrink-0 flex items-center justify-center w-5 h-5 rounded-full bg-[#0284C7] text-white text-[10px] font-semibold mt-0.5">3</span>
                        <span>14 Tage kostenlos testen</span>
                      </li>
                    </ul>
                  </div>

                  <button
                    type="button"
                    onClick={closeRegistrationModal}
                    className="inline-flex items-center gap-2 text-[13px] text-[#0284C7] hover:text-[#0369A1] font-medium transition-colors duration-150"
                  >
                    <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                      <path strokeLinecap="round" strokeLinejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Zurück zur Login-Seite
                  </button>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
      </div>
    </>
  );
}
