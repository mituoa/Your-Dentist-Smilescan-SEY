type Explanation = {
  id: string;
  title: string;
  content: string;
  date: string;
  published: boolean;
  publishedAt?: string;
};

const GUIDED_QUESTIONS = [
  'Was tun bei Zahnschmerzen?',
  'Was passiert bei einer Wurzelbehandlung?',
  'Wann ist ein Implantat sinnvoll?',
  'Wie läuft eine professionelle Zahnreinigung ab?',
  'Was sollte ich nach dem Eingriff beachten?',
  'Wie oft sollte ich zur Kontrolle kommen?',
];

export default function Journals() {
  const [activeTab, setActiveTab] = useState('journals');
  const [contentView, setContentView] = useState<'create' | 'published' | 'drafts'>('create');
  const [isWriting, setIsWriting] = useState(false);
  const [explanations, setExplanations] = useState<Explanation[]>([]);
  const [newTitle, setNewTitle] = useState('');
  const [newContent, setNewContent] = useState('');
  const [editingId, setEditingId] = useState<string | null>(null);
  const [hoveredItemId, setHoveredItemId] = useState<string | null>(null);
  const navigate = useNavigate();

  const handleLogout = () => {
    navigate('/');
  };

  // AI Draft Generator (simplified simulation)
  const generateDraft = (title: string): string => {
    const drafts: Record<string, string> = {
      'Was tun bei Zahnschmerzen?': 'Bei plötzlichen Zahnschmerzen sollten Sie zunächst die betroffene Stelle vorsichtig reinigen. Spülen Sie Ihren Mund mit lauwarmem Wasser.\n\n\nKühlen Sie die Wange von außen – das lindert die Schwellung. Vermeiden Sie heiße oder sehr kalte Speisen.\n\n\nWenn der Schmerz stark ist oder länger als einen Tag anhält, vereinbaren Sie einen Termin. Wir finden gemeinsam heraus, was die Ursache ist.',
      'Was passiert bei einer Wurzelbehandlung?': 'Eine Wurzelbehandlung klingt komplizierter, als sie ist. Wir entfernen das entzündete Gewebe aus dem Zahninneren und reinigen die Kanäle gründlich.\n\n\nDer Zahn wird dabei betäubt – Sie spüren nichts. Die Behandlung selbst dauert etwa 45 bis 60 Minuten.\n\n\nDanach verschließen wir den Zahn wieder. In den meisten Fällen bleibt der Zahn dadurch erhalten und funktioniert normal weiter.',
      'Wann ist ein Implantat sinnvoll?': 'Ein Implantat macht Sinn, wenn ein Zahn fehlt und die Nachbarzähne gesund sind. Anders als bei einer Brücke müssen wir diese nicht beschleifen.\n\n\nDas Implantat sitzt fest im Kiefer – wie eine neue Zahnwurzel. Darauf setzen wir eine Krone, die aussieht und funktioniert wie Ihr eigener Zahn.\n\n\nWir besprechen vorher gemeinsam, ob ein Implantat in Ihrer Situation die beste Lösung ist.',
      'Wie läuft eine professionelle Zahnreinigung ab?': 'Die professionelle Zahnreinigung entfernt Beläge, die Sie mit der Zahnbürste nicht erreichen. Wir reinigen zunächst alle Zahnflächen und Zwischenräume gründlich.\n\n\nDanach polieren wir die Zähne und versiegeln sie mit Fluorid. Das stärkt den Zahnschmelz.\n\n\nDie Behandlung dauert etwa 45 Minuten und ist in der Regel nicht schmerzhaft. Sie verlassen die Praxis mit einem spürbar sauberen Gefühl.',
      'Was sollte ich nach dem Eingriff beachten?': 'In den ersten Stunden nach der Betäubung sollten Sie nichts essen – Sie könnten sich unbemerkt verletzen.\n\n\nTrinken Sie erst, wenn die Betäubung vollständig abgeklungen ist. Vermeiden Sie am ersten Tag heiße Getränke und körperliche Anstrengung.\n\n\nWenn Sie Schmerzen haben, nehmen Sie die empfohlenen Schmerzmittel. Bei ungewöhnlichen Beschwerden rufen Sie uns an – wir sind für Sie da.',
      'Wie oft sollte ich zur Kontrolle kommen?': 'Die meisten Patienten kommen zweimal im Jahr zur Kontrolle. So können wir Probleme frühzeitig erkennen, bevor sie größer werden.\n\n\nBei erhöhtem Risiko – etwa bei Parodontitis – empfehlen wir kürzere Abstände. Das besprechen wir individuell.\n\n\nRegelmäßige Kontrollen sind der beste Schutz für Ihre Zähne. Die Termine sind kurz, und wir schauen nur, dass alles in Ordnung ist.',
    };

    return drafts[title] || 'Schreiben Sie hier Ihre Erklärung für Patienten.\n\n\nDenken Sie daran: kurz, klar und verständlich.';
  };

  const handleStartWriting = (prefilledTitle = '') => {
    setNewTitle(prefilledTitle);
    setNewContent(prefilledTitle ? generateDraft(prefilledTitle) : '');
    setIsWriting(true);
  };

  const handleShorter = () => {
    if (newContent.trim()) {
      // Simulate "make shorter" - remove middle paragraph
      const paragraphs = newContent.split('\n\n\n');
      if (paragraphs.length > 2) {
        setNewContent([paragraphs[0], paragraphs[paragraphs.length - 1]].join('\n\n\n'));
      }
    }
  };

  const handleSimpler = () => {
    if (newContent.trim()) {
      // Simulate "make simpler" - this would call AI in real implementation
      setNewContent(newContent.replace(/zunächst/g, 'zuerst').replace(/etwa/g, 'ungefähr'));
    }
  };

  const getRelativeTime = (timestamp: string): string => {
    const now = new Date();
    const date = new Date(timestamp);
    const diffMs = now.getTime() - date.getTime();
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

    if (diffDays === 0) return 'Heute veröffentlicht';
    if (diffDays === 1) return 'Gestern veröffentlicht';
    if (diffDays < 7) return `Vor ${diffDays} Tagen veröffentlicht`;
    if (diffDays < 30) return `Vor ${Math.floor(diffDays / 7)} Wochen veröffentlicht`;
    return date.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
  };

  const handleSave = (publish = true) => {
    if (newTitle.trim() && newContent.trim()) {
      if (editingId) {
        // Update existing
        setExplanations(explanations.map(exp =>
          exp.id === editingId
            ? { ...exp, title: newTitle, content: newContent, published: publish, publishedAt: publish ? new Date().toISOString() : exp.publishedAt }
            : exp
        ));
        setEditingId(null);
      } else {
        // Create new
        const newExplanation: Explanation = {
          id: Date.now().toString(),
          title: newTitle,
          content: newContent,
          date: new Date().toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' }),
          published: publish,
          publishedAt: publish ? new Date().toISOString() : undefined,
        };
        setExplanations([newExplanation, ...explanations]);
      }
      setNewTitle('');
      setNewContent('');
      setIsWriting(false);
    }
  };

  const handleEdit = (explanation: Explanation) => {
    setNewTitle(explanation.title);
    setNewContent(explanation.content);
    setEditingId(explanation.id);
    setIsWriting(true);
  };

  const handleCancel = () => {
    setNewTitle('');
    setNewContent('');
    setEditingId(null);
    setIsWriting(false);
  };

  const publishedExplanations = explanations.filter(e => e.published).slice(0, 7);
  const draftExplanations = explanations.filter(e => !e.published).slice(0, 5);

  // Dynamic page title
  const getPageTitle = () => {
    switch (contentView) {
      case 'create':
        return 'Erklärungen erstellen';
      case 'published':
        return 'Veröffentlichte Inhalte';
      case 'drafts':
        return 'Entwürfe';
      default:
        return 'Erklärungen für Patienten';
    }
  };

  // Dynamic subtitle
  const getPageSubtitle = () => {
    switch (contentView) {
      case 'create':
        return 'Geben Sie Ihren Patienten Klarheit – bevor sie fragen müssen';
      case 'published':
        return 'Ihre veröffentlichten Erklärungen für Patienten';
      case 'drafts':
        return 'Unfertige Erklärungen, an denen Sie arbeiten';
      default:
        return '';
    }
  };

  return (
    <div className="min-h-screen flex relative" style={{ background: '#F8FAFC' }}>
      {/* Ambient gradient */}
      <div className="absolute inset-0 pointer-events-none"
        style={{ background: 'radial-gradient(circle at top right, rgba(47,128,237,0.05), transparent 32%)' }}
      />

      {/* SIDEBAR */}
      <aside className="w-[280px] bg-white/95 backdrop-blur-xl border-r flex flex-col relative z-10"
        style={{ borderColor: '#EEF2F6' }}>

        {/* Logo */}
        <div className="px-6 border-b" style={{ borderColor: '#EEF2F6', height: '80px', display: 'flex', alignItems: 'center' }}>
          <div className="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 256 256" fill="none" className="w-11 h-11">
              <defs>
                <linearGradient id="logo-journals" x1="50" y1="42" x2="210" y2="214" gradientUnits="userSpaceOnUse">
                  <stop stopColor="#FFFFFF"/>
                  <stop offset="1" stopColor="#E3F2FD"/>
                </linearGradient>
              </defs>
              <rect x="42" y="42" width="172" height="172" rx="48" fill="url(#logo-journals)"/>
              <rect x="42.75" y="42.75" width="170.5" height="170.5" rx="47.25" stroke="#2F80ED" strokeOpacity="0.18" strokeWidth="1.5"/>
              <path d="M92 90C103 81.333 115 77 128 77C141 77 153 81.333 164 90" stroke="#2F80ED" strokeOpacity="0.34" strokeWidth="9" strokeLinecap="round"/>
              <path d="M99 103L128 131L157 103" stroke="#2F80ED" strokeWidth="11" strokeLinecap="round" strokeLinejoin="round"/>
              <path d="M128 130V157" stroke="#2F80ED" strokeWidth="11" strokeLinecap="round"/>
              <path d="M96 171C106.333 181 117 186 128 186C139 186 149.667 181 160 171" stroke="#2F80ED" strokeWidth="10" strokeLinecap="round"/>
            </svg>
            <div>
              <h1 className="text-[19px] font-medium text-gray-900 tracking-tight leading-none">
                <span className="italic font-light">Your</span> Dentist
              </h1>
              <p className="text-[9px] font-semibold text-[#2F80ED] uppercase tracking-[0.15em] mt-0.5">
                Neutral Practice Platform
              </p>
            </div>
          </div>
        </div>

        {/* Navigation */}
        <nav className="flex-1 px-4 pt-6 pb-4 space-y-2">
          <button onClick={() => navigate('/dashboard')} className="group w-full flex items-center gap-3.5 px-3 rounded-xl relative hover:bg-[#F8FAFC]" style={{ height: '56px', transition: 'all 180ms ease' }}>
            <div className="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0">
              <img src={logoAtlas} alt="Atlas" className="w-8 h-8 opacity-80" />
            </div>
            <div className="flex-1 text-left">
              <span className="block text-[15px] font-medium" style={{ color: '#64748B' }}>Atlas</span>
              <span className="block text-[11px] font-medium" style={{ color: '#94A3B8' }}>Dashboard</span>
            </div>
          </button>

          <button onClick={() => navigate('/dashboard')} className="group w-full flex items-center gap-3.5 px-3 rounded-xl relative hover:bg-[#F8FAFC]" style={{ height: '56px', transition: 'all 180ms ease' }}>
            <div className="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0">
              <img src={logoSmileScan} alt="Tracker" className="w-8 h-8 opacity-80" />
            </div>
            <div className="flex-1 text-left">
              <span className="block text-[15px] font-medium" style={{ color: '#64748B' }}>Tracker</span>
              <span className="block text-[11px] font-medium" style={{ color: '#94A3B8' }}>Intake & Triage</span>
            </div>
          </button>

          <button onClick={() => navigate('/relay')} className="group w-full flex items-center gap-3.5 px-3 rounded-xl relative hover:bg-[#F8FAFC]" style={{ height: '56px', transition: 'all 180ms ease' }}>
            <div className="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0">
              <img src={logoRelay} alt="Relay" className="w-8 h-8 opacity-80" />
            </div>
            <div className="flex-1 text-left">
              <span className="block text-[15px] font-medium" style={{ color: '#64748B' }}>Relay</span>
              <span className="block text-[11px] font-medium" style={{ color: '#94A3B8' }}>Aufgaben</span>
