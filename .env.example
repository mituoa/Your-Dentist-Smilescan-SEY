# --- Notfall-Login OHNE GitHub/Google: beliebige E-Mail + Passwort (von DIR gewählt, nicht von GitHub kopiert).
# Server legt den Supabase-User an oder setzt das Passwort (Service Role). GitHub-OAuth wird nicht gebraucht.
EMERGENCY_PASSWORD_LOGIN_ENABLED=false
EMERGENCY_LOGIN_EMAIL=team@deine-echte-domain.de
EMERGENCY_LOGIN_PASSWORD=wirklich_geheimes_passwort_aendern

# Server: /inbox-preview bei false oder 0 ausblenden (404). Nicht NEXT_PUBLIC — kein Leak ins Client-Bundle. Leer = Route aktiv.
INBOX_PREVIEW_ENABLED=

# Demo-Registrierung: zweiter Button auf /register „ohne Zahlung“ — nur zusammen mit REGISTRATION_DEMO_MODE sinnvoll.
NEXT_PUBLIC_REGISTRATION_DEMO_MODE=false
# Server: erlaubt Überspringen von Stripe-Checkout wenn Formular registration_demo_skip=1 mitschickt (kein UI ohne NEXT_PUBLIC_*).
REGISTRATION_DEMO_MODE=false

# Stripe-Checkout direkt nach Registrierung (nur wenn STRIPE_* + Preis-IDs vollständig). Standard: aus = kein Zwang.
ENABLE_STRIPE_CHECKOUT_AT_SIGNUP=false

# true = Nutzer ohne bestätigte E-Mail dürfen /dashboard nicht betreten (Supabase „Confirm email“). Standard: aus für Demo/Launch.
REQUIRE_EMAIL_CONFIRMATION_BEFORE_APP=false

# true = Workspace muss per Admin freigeschaltet sein (`approved_at`), sonst Login-Hinweis account_pending_approval. Ausnahmen: AUTH_RELAX_MODE, ADMIN_EMAILS / ADMIN_GITHUB_USERNAMES.
REQUIRE_WORKSPACE_APPROVAL_BEFORE_APP=false

# NOTFALL / Demo: true = E-Mail-Bestätigung + manuelle Praxis-Freischaltung überspringen; legt ggf. Demo-Workspace an
# Benötigt SUPABASE_SERVICE_ROLE_KEY. Für Live-Betrieb: false oder Variable entfernen.
AUTH_RELAX_MODE=false

# Komma-getrennt: umgeht Workspace-Freischaltung (E-Mail = Login in der App, wie in Supabase Auth)
ADMIN_EMAILS=ops@deinedomain.de
# Optional: GitHub-Nutzername(n) statt E-Mail für dieselbe Ops-Freigabe (z. B. OAuth ohne sichtbare Mail)
ADMIN_GITHUB_USERNAMES=deingithublogin

# Supabase
NEXT_PUBLIC_APP_URL=https://deine-site.netlify.app
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMTP (Terminlinks, Team-Einladungen, Passwort-Reset mit Absender „Your Dentist“)
# Passwort-Reset: zusätzlich SUPABASE_SERVICE_ROLE_KEY nötig (generiert sicheren Link).
SMTP_HOST=host285.checkdomain.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@deinedomain.de
SMTP_PASS=your_smtp_password
SMTP_FROM=Your Dentist <noreply@deinedomain.de>
SMTP_REPLY_TO=

# Demo-Anfragen (öffentliches Formular) — Empfänger; Fallback: erster Eintrag in ADMIN_EMAILS
# DEMO_REQUEST_TO=team@deinedomain.de
