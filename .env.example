# Komma-getrennt, Kleinbuchstaben egal: umgeht Workspace-Freischaltung zum Testen / Registrierungen freigeben
ADMIN_EMAILS=ops@deinedomain.de

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
