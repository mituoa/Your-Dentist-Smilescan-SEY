# SMTP (optional - für Terminlink-E-Mails)
SMTP_HOST=host285.checkdomain.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@deinedomain.de
SMTP_PASS=your_smtp_password
SMTP_FROM=SmileScan <noreply@deinedomain.de>
SMTP_REPLY_TO=
